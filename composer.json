{
    "name": "mg/laraimporter",
    "description": "Universal database import wizard for Laravel — CSV, Excel, JSON with column mapping, related tables, many-to-many, queue support, and MongoDB.",
    "keywords": ["laravel", "import", "csv", "excel", "database", "wizard", "migration"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0"
    },
    "suggest": {
        "phpoffice/phpspreadsheet": "Required for XLS, XLSX, ODS file support (^5.0)",
        "mongodb/laravel-mongodb": "Required for MongoDB support (^5.0)"
    },
    "autoload": {
        "psr-4": {
            "LaraImporter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraImporter\\LaraImporterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
